<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <title>List</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body{
            background: linear-gradient(135deg, #e7abc2, rgb(216, 176, 228));
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .title{
            text-align: center;
            margin-bottom: 30px;
            color: #d63384;
            font-weight: 700;
        }

        .table-container{
            background: white;
            padding: 40px;
            border-radius: 25px;
            width: 50%;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .table-thead{
            background: #d63384;
            color: white;
        }

        .btn-edit{
            background: #d63384;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 10px;
            text-decoration: none;
        }

        .btn-delete{
            background: #ec4564;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 10px;
        }

        .btn-edit:hover, .btn-delete:hover{
            opacity: 0.8;
        }
    </style>
</head>
<body>
    <div class="table-container">
        <h1 class="title">Lista de Usuário</h1>
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Senha</th>
                        <th>Ações</th>
                    </tr>
                </thead>
        
                <tbody>
                    <% for(usuario of usuarios) {%>
                        <tr>
                            <td><%= usuario.id %></td>
                            <td><%= usuario.nome %></td>
                            <td><%= usuario.email %></td>
                            <td><%= usuario.senha %></td>
                            <td class="d-flex gap-2">
                                <a href="/user/edit/<%= usuario.id %>" class="btn-edit">Editar</a>
                                <button onclick="apagarUsuario('<%= usuario.id %>')" id="btnApagar" class="btn-delete">Apagar</button>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </body>
    </div>
<script>
    async function apagarUsuario(id){
        const url = "/user/delete/"+id

        const response = await fetch(url,{method:'DELETE',})

        const data = await response.json()

        if(!response.ok){
            console.log("Ocorreu um erro na requisição")
        }

        console.log(data)
        location.reload()
    }
</script>
</html>